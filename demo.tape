# peasy-image-rs — Image resize, crop, convert (Rust)
# Theme: Gruvbox
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "GruvboxDark"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-image-rs — Image resize, crop, convert for Rust"
Enter
Type "# peasyimage.com"
Enter
Sleep 500ms

# Run the demo
Type "cargo run --example demo 2>/dev/null"
Enter
Sleep 5s
